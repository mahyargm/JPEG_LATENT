{
    "MSE_FixedRate_64":
        [
            "--epochs",
            64,
            "--loss_type",
            "mse",
            "--base_warmup_epoch",
            ${ if args.base_warmup_epoch is None: }$ 1.0 ${ :else: }$ ${ write(args.base_warmup_epoch) }$ ${ :end-if }$,
            "--lr",
            ${ if args.lr is None: }$ 1e-03 ${ :else: }$ ${ write(args.lr) }$ ${ :end-if }$,
            "--anneal_final_lr",
            ${ if args.anneal_final_lr is None: }$ 1e-04 ${ :else: }$ ${ write(args.anneal_final_lr) }$ ${ :end-if }$,
            "--frozen_part", "gain_unit",
            "--beta_list", 
            ${ beta }$
        ],
    "Mixed_FixedRate_36": [
            "--beta_list",
            ${ beta_list_stageII }$,
            "--epochs",
            36,
            "--loss_type",
            "mix",
            "--msssim_weight",
            ${ msssim_weight }$,
            "--loss_factors",
            "${ loss_factors }$",
            "--base_warmup_epoch",
            ${ if args.base_warmup_epoch is None: }$ 0.1 ${ :else: }$ ${ write(args.base_warmup_epoch) }$ ${ :end-if }$,
            "--lr",
            ${ if args.lr is None: }$ 1e-04 ${ :else: }$ ${ write(args.lr) }$ ${ :end-if }$,
            "--anneal_final_lr",
            ${ if args.anneal_final_lr is None: }$ 1e-05 ${ :else: }$ ${ write(args.anneal_final_lr) }$ ${ :end-if }$,
            "--frozen_part", "gain_unit"
        ],
    "Mixed_FixedRate_OnlyDec_20": [
            "--beta_list",
            ${ beta_list_stageIII_IV }$,
            "--epochs",
            20,
            "--loss_type",
            "mix",
            "--msssim_weight",
            ${ msssim_weight }$,
            "--loss_factors",
            "${ loss_factors }$",
            "--base_warmup_epoch",
            ${ if args.base_warmup_epoch is None: }$ 0.1 ${ :else: }$ ${ write(args.base_warmup_epoch) }$ ${ :end-if }$,
            "--lr",
            ${ if args.lr is None: }$ 1e-04 ${ :else: }$ ${ write(args.lr) }$ ${ :end-if }$,
            ${ if beta == 0.002: }$ "--frozen_part", "gain_unit",${ :end-if }$
            "--anneal_final_lr",
            ${ if args.anneal_final_lr is None: }$ 1e-05 ${ :else: }$ ${ write(args.anneal_final_lr) }$ ${ :end-if }$,
            "--enable_gvae",
            ${ if beta == 0.002: }$ 0 ${ :else: }$ 1 ${ :end-if }$
        ],
    "MSE_VariableRate_12":
        [
            "--beta_list",
            ${ beta_list_stageIII_IV }$,
            "--epochs",
            12,
            "--loss_type",
            "mix",
            "--msssim_weight",
            ${ msssim_weight }$,
            "--loss_factors",
            "${ loss_factors }$",
            "--base_warmup_epoch",
            ${ if args.base_warmup_epoch is None: }$ 0.1 ${ :else: }$ ${ write(args.base_warmup_epoch) }$ ${ :end-if }$,
            "--lr",
            1e-4,
            "--cal_entropy_on_val",
            1,
            "--anneal_final_lr",
            1e-5,
            "--frozen_part", "analysis", "entropy",
            ${ if beta == 0.002: }$ "synthesis", ${ :end-if }$
            "--add_random_noise_for_quantization_y",
            1,
            "--enable_gvae",
            ${ if beta == 0.002: }$ 0 ${ :else: }$ 1 ${ :end-if }$
        ], 
    "Data_Collection":
        [
            "--beta_list",
            ${ beta_list_stageIII_IV }$,
            "--epochs",
            1,
            "--loss_type",
            "mix",
            "--msssim_weight",
            ${ msssim_weight }$,
            "--loss_factors",
            "${ loss_factors }$",
            "--base_warmup_epoch",
            ${ if args.base_warmup_epoch is None: }$ 0.1 ${ :else: }$ ${ write(args.base_warmup_epoch) }$ ${ :end-if }$,
            "--lr",
            1e-4,
            "--anneal_final_lr",
            1e-5,
            "--frozen_part", "gain_unit",
            "--collect_only", 
            1
        ]        
}
